classDiagram
    class Owner {
        +str owner_id
        +str name
        +str email
        +float available_hours_per_day
        +list pets
        +add_pet(pet: Pet) void
        +remove_pet(pet_id: str) void
        +get_all_pets() list
    }

    class Pet {
        +str pet_id
        +str name
        +str species
        +str breed
        +int age_months
        +str energy_level
        +list medical_notes
        +dict preferences
        +update_profile(data: dict) void
        +get_care_summary() str
    }

    class Task {
        +str task_id
        +str title
        +str category
        +int duration_minutes
        +str priority
        +str time_slot_preference
        +bool is_recurring
        +str recurrence_pattern
        +bool is_completed
        +mark_as_completed() void
        +update_task_details(data: dict) void
        +is_urgent() bool
    }

    class DailyScheduler {
        +Owner owner
        +date target_date
        +int daily_time_limit_minutes
        +list task_pool
        +list scheduled_tasks
        +list unscheduled_tasks
        +list decision_log
        +add_task_to_pool(task: Task, pet: Pet) void
        +generate_schedule() list
        +resolve_conflicts() void
        +get_reasoning() list
    }

    Owner "1" --> "*" Pet : owns
    DailyScheduler --> Owner : schedules_for
    DailyScheduler "*" --> "*" Task : schedules
    Task "*" --> "1" Pet : targets
